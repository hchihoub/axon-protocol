{
  "name": "@axon-protocol/sdk",
  "version": "0.1.0",
  "description": "AXON Protocol SDK — Next-generation tool protocol for AI agents with out-of-context storage, lazy discovery, and capability-based security",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "src",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsc",
    "prepublishOnly": "npm run build",
    "test": "vitest run",
    "test:watch": "vitest",
    "benchmark": "npx tsx ../tests/benchmark.ts",
    "example": "npx tsx ../examples/filesystem-server.ts"
  },
  "keywords": [
    "axon",
    "protocol",
    "ai",
    "agent",
    "tools",
    "mcp",
    "mcp-alternative",
    "context-window",
    "browser-automation",
    "ocrs"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/hchihoub/axon-protocol.git",
    "directory": "sdk"
  },
  "homepage": "https://github.com/hchihoub/axon-protocol#readme",
  "bugs": {
    "url": "https://github.com/hchihoub/axon-protocol/issues"
  },
  "author": "AXON Protocol Contributors",
  "license": "MIT",
  "devDependencies": {
    "@types/node": "^25.5.0",
    "tsx": "^4.7.0",
    "typescript": "^5.4.0",
    "vitest": "^3.0.0"
  }
}
